{% comment %}
  Stringer Music - Custom Product Card
  Matches the screenshot: Gray BG, Bold Playfair Headings. (No Ratings)
{% endcomment %}

<div class="product-card-stringer">
  <a href="{{ product.url }}" class="pcs__link">
    
    {% comment %} Image Wrapper with Gray Background {% endcomment %}
    <div class="pcs__image-wrapper">
      {%- if product.featured_media -%}
        {{ product.featured_media | image_url: width: 600 | image_tag: 
          loading: 'lazy', 
          class: 'pcs__image',
          widths: '200, 400, 600',
          alt: product.title 
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'pcs__placeholder' }}
      {%- endif -%}
    </div>

    {% comment %} Content Area {% endcomment %}
    <div class="pcs__info">
      <h3 class="pcs__title">{{ product.title }}</h3>
      
      <div class="pcs__price">
        {{ product.price | money_without_trailing_zeros }}
      </div>
    </div>
  </a>
</div>

<style>
  .product-card-stringer {
    width: 100%;
    transition: transform 0.3s ease;
  }

  .pcs__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .pcs__image-wrapper {
    background-color: #F1F1F1; /* The gray from your screenshot */
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .pcs__image {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  .pcs__title {
    font-family: var(--type_header_font, 'Playfair Display', serif);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.4;
    color: #1A1710;
    margin: 8px 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 42px;
  }

  .pcs__price {
    font-family: var(--type_header_font, 'Playfair Display', serif);
    font-size: 22px;
    font-weight: 900;
    color: #1A1710;
    letter-spacing: -0.02em;
  }

  /* Hover Effects */
  .product-card-stringer:hover .pcs__image {
    transform: scale(1.08);
  }
  .product-card-stringer:hover .pcs__title {
    color: #C8420A; /* Stringer Rust Color */
  }
</style>