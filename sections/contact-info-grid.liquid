{%- comment -%}
  Stringer Music - Contact Info Grid
  Flat, minimalist cards for Phone, Email, and Location.
{%- endcomment -%}

<section class="ci-section">
  <div class="ci-container">
    
    <div class="ci-header">
      <h1 class="ci-heading">{{ section.settings.heading }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="ci-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="ci-grid">
      {%- for block in section.blocks -%}
        <div class="ci-card" {{ block.shopify_attributes }}>
          <div class="ci-icon-wrapper">
            {%- case block.settings.icon -%}
              {%- when 'phone' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              {%- when 'mail' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              {%- when 'map-pin' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              {%- when 'chat' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            {%- endcase -%}
          </div>
          <h3 class="ci-card-title">{{ block.settings.title }}</h3>
          <div class="ci-card-text">{{ block.settings.text }}</div>
          {%- if block.settings.link_label != blank -%}
            <a href="{{ block.settings.link_url }}" class="ci-card-link">{{ block.settings.link_label }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .ci-section { padding: 60px 0 40px 0; background-color: #FFFFFF; --brand-ink: #1A1710; --brand-rust: #C8420A; }
  .ci-container { max-width: 1200px; margin: 0 auto; padding: 0 5%; }
  
  .ci-header { text-align: center; margin-bottom: 50px; }
  .ci-heading { font-family: var(--type_header_font, 'Playfair Display', serif); font-size: clamp(36px, 5vw, 54px); font-weight: 900; color: var(--brand-ink); margin: 0 0 12px 0; letter-spacing: -0.015em; }
  .ci-subheading { font-family: var(--type_body_font, 'DM Sans', sans-serif); font-size: 16px; color: rgba(26,23,16,0.6); margin: 0; max-width: 600px; margin: 0 auto; }

  .ci-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
  
  .ci-card {
    background: #FFFFFF;
    border: 1px solid rgba(26, 23, 16, 0.2); /* Crisp border matching filters */
    border-radius: 2px; /* Sharp corners */
    padding: 40px 30px;
    text-align: center;
    transition: border-color 0.2s ease;
  }
  .ci-card:hover { border-color: var(--brand-ink); }

  .ci-icon-wrapper { margin-bottom: 20px; color: var(--brand-ink); transition: color 0.2s ease; }
  .ci-icon-wrapper svg { width: 32px; height: 32px; }
  .ci-card:hover .ci-icon-wrapper { color: var(--brand-rust); }

  .ci-card-title { font-family: var(--type_header_font, 'Playfair Display', serif); font-size: 22px; font-weight: 700; color: var(--brand-ink); margin: 0 0 12px 0; }
  .ci-card-text { font-family: var(--type_body_font, 'DM Sans', sans-serif); font-size: 15px; color: rgba(26,23,16,0.7); line-height: 1.6; margin-bottom: 20px; }
  .ci-card-text p { margin: 0 0 8px 0; }
  
  .ci-card-link {
    display: inline-block;
    font-family: var(--type_body_font, 'DM Sans', sans-serif);
    font-size: 14px; font-weight: 700; color: var(--brand-rust); text-decoration: none;
    text-transform: uppercase; letter-spacing: 0.5px;
    transition: color 0.2s ease;
  }
  .ci-card-link:hover { color: var(--brand-ink); }
</style>

{% schema %}
{
  "name": "Contact Info Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "We're here to help." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Our team of gear experts is ready to answer your questions." }
  ],
  "blocks": [
    {
      "type": "info_card",
      "name": "Info Card",
      "limit": 4,
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon",
          "options": [
            { "value": "phone", "label": "Phone" },
            { "value": "mail", "label": "Email" },
            { "value": "map-pin", "label": "Map Pin" },
            { "value": "chat", "label": "Chat Bubble" }
          ],
          "default": "phone"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Call Us" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>1-800-555-0199</p><p>Mon-Fri: 9am - 6pm EST</p>" },
        { "type": "text", "id": "link_label", "label": "Link Label", "default": "Call Now" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Info Grid",
      "blocks": [
        { "type": "info_card", "settings": { "icon": "phone", "title": "Sales & Support", "link_label": "Call Now" } },
        { "type": "info_card", "settings": { "icon": "mail", "title": "Email Us", "link_label": "Send Email" } },
        { "type": "info_card", "settings": { "icon": "map-pin", "title": "Visit the Store", "link_label": "Get Directions" } }
      ]
    }
  ]
}
{% endschema %}