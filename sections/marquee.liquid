{%- comment -%}
  Stringer Music - Scrolling Marquee
  A pure CSS infinite scrolling ticker for brands or announcements.
{%- endcomment -%}

<section 
  class="sm-section" 
  id="sm-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --accent-color: {{ section.settings.accent_color }};
    --scroll-speed: {{ section.settings.speed }}s;
    --scroll-direction: {{ section.settings.direction }};
  "
>
  <div class="sm-wrapper">
    
    {%- comment -%} 
      We duplicate the inner track so the animation can loop seamlessly.
      The aria-hidden true on the second one prevents screen readers from reading it twice.
    {%- endcomment -%}
    
    <div class="sm-track">
      {%- for i in (1..3) -%} {%- comment -%} Repeat the block list to ensure it fills the screen {%- endcomment -%}
        {%- for block in section.blocks -%}
          <div class="sm-item" {{ block.shopify_attributes }}>
            <span class="sm-text">{{ block.settings.text }}</span>
            <span class="sm-divider">◆</span>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
    
    <div class="sm-track" aria-hidden="true">
      {%- for i in (1..3) -%}
        {%- for block in section.blocks -%}
          <div class="sm-item">
            <span class="sm-text">{{ block.settings.text }}</span>
            <span class="sm-divider">◆</span>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% stylesheet %}
  /* ════════════════════════════════════════════
     BASE STYLING & VARIABLES
  ════════════════════════════════════════════ */
  .sm-section {
    --font-heading: var(--type_header_font, 'Playfair Display', serif);
    padding: 16px 0;
    overflow: hidden;
    position: relative;
    border-top: 1px solid rgba(245, 240, 232, 0.1);
    border-bottom: 1px solid rgba(245, 240, 232, 0.1);
  }

  .sm-wrapper {
    display: flex;
    width: fit-content;
    white-space: nowrap;
    /* CSS Animation for the scroll */
    animation: sm-scroll var(--scroll-speed) linear infinite var(--scroll-direction);
  }

  /* Pause the animation if the user hovers over it (optional, but good UX) */
  .sm-section:hover .sm-wrapper {
    animation-play-state: paused;
  }

  /* ════════════════════════════════════════════
     TRACK & ITEMS
  ════════════════════════════════════════════ */
  .sm-track {
    display: flex;
    min-width: max-content;
  }

  .sm-item {
    display: flex;
    align-items: center;
    padding: 0 40px; /* Space between each word */
  }

  .sm-text {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-color);
  }

  /* The little diamond divider */
  .sm-divider {
    font-size: 10px;
    color: var(--accent-color);
    margin-left: 80px; /* Adds gap after the text before the diamond */
  }

  /* ════════════════════════════════════════════
     KEYFRAMES FOR SCROLLING
  ════════════════════════════════════════════ */
  @keyframes sm-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Translates exactly half of the wrapper (one full track length) to loop perfectly */
      transform: translateX(-50%); 
    }
  }

  /* Respect user preferences for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .sm-wrapper {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
    }
    .sm-track:nth-child(2) {
      display: none; /* Hide the duplicate track if not animating */
    }
  }
  
  /* Make the text slightly smaller on phones */
  @media screen and (max-width: 749px) {
    .sm-text { font-size: 12px; }
    .sm-item { padding: 0 24px; }
    .sm-divider { margin-left: 48px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Scrolling Marquee",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1A1710" 
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#F5F0E8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Divider Color (Diamond)",
      "default": "#C8420A"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "s",
      "default": 30,
      "info": "Lower number is faster."
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        { "value": "normal", "label": "Right to Left" },
        { "value": "reverse", "label": "Left to Right" }
      ],
      "default": "normal"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Marquee Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "BRAND NAME"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling Marquee",
      "blocks": [
        { "type": "text", "settings": { "text": "YAMAHA" } },
        { "type": "text", "settings": { "text": "FENDER" } },
        { "type": "text", "settings": { "text": "ROLAND" } },
        { "type": "text", "settings": { "text": "GIBSON" } },
        { "type": "text", "settings": { "text": "SHURE" } },
        { "type": "text", "settings": { "text": "KORG" } }
      ]
    }
  ]
}
{% endschema %}