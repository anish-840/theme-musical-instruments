{%- comment -%}
  Stringer Music - Premium Split Contact Form
  Working Shopify form on the left, Image or text on the right.
{%- endcomment -%}

<section class="pcf-section">
  <div class="pcf-container">
    <div class="pcf-grid">
      
      {%- comment -%} Left Column: The Form {%- endcomment -%}
      <div class="pcf-form-col">
        <h2 class="pcf-heading">{{ section.settings.form_heading }}</h2>
        <p class="pcf-subheading">{{ section.settings.form_subheading }}</p>

        {%- form 'contact', id: 'PremiumContactForm', class: 'pcf-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="pcf-success-msg" tabindex="-1" autofocus>
              Thanks for reaching out! We will get back to you within 24 hours.
            </div>
          {%- elsif form.errors -%}
            <div class="pcf-error-msg">
              Oops! Please check the highlighted fields below.
            </div>
          {%- endif -%}

          <div class="pcf-input-group">
            <div class="pcf-input-wrapper">
              <label for="ContactForm-name" class="pcf-label">Name</label>
              <input class="pcf-input" autocomplete="name" type="text" id="ContactForm-name" name="contact[Name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="John Doe">
            </div>
            <div class="pcf-input-wrapper">
              <label for="ContactForm-email" class="pcf-label">Email <span aria-hidden="true">*</span></label>
              <input class="pcf-input {% if form.errors contains 'email' %}pcf-input--error{% endif %}" autocomplete="email" type="email" id="ContactForm-email" name="contact[email]" spellcheck="false" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" aria-required="true" placeholder="john@example.com" required>
            </div>
          </div>

          <div class="pcf-input-wrapper">
            <label for="ContactForm-phone" class="pcf-label">Phone Number (Optional)</label>
            <input class="pcf-input" type="tel" id="ContactForm-phone" autocomplete="tel" name="contact[Phone number]" pattern="[0-9\-]*" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" placeholder="123-456-7890">
          </div>

          <div class="pcf-input-wrapper">
            <label for="ContactForm-body" class="pcf-label">Message <span aria-hidden="true">*</span></label>
            <textarea class="pcf-textarea" rows="5" id="ContactForm-body" name="contact[Comment]" placeholder="How can we help you today?" required>
              {{- form.body -}}
            </textarea>
          </div>

          <button type="submit" class="pcf-submit-btn">
            Send Message
          </button>
        {%- endform -%}
      </div>

      {%- comment -%} Right Column: The Image/Side Text {%- endcomment -%}
      <div class="pcf-image-col">
        {%- if section.settings.side_image != blank -%}
          {{ section.settings.side_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'pcf-side-img', alt: 'Support Team' }}
        {%- else -%}
          <div class="pcf-placeholder-img">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'pcf-placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  .pcf-section { padding: 40px 0 100px 0; background-color: #FFFFFF; --brand-ink: #1A1710; --brand-rust: #C8420A; }
  .pcf-container { max-width: 1200px; margin: 0 auto; padding: 0 5%; }
  
  .pcf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: stretch; }

  /* Left Side: Typography & Form */
  .pcf-heading { font-family: var(--type_header_font, 'Playfair Display', serif); font-size: 36px; font-weight: 700; color: var(--brand-ink); margin: 0 0 12px 0; }
  .pcf-subheading { font-family: var(--type_body_font, 'DM Sans', sans-serif); font-size: 16px; color: rgba(26,23,16,0.7); margin: 0 0 30px 0; }

  .pcf-form { display: flex; flex-direction: column; gap: 20px; }
  
  .pcf-input-group { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  
  .pcf-input-wrapper { display: flex; flex-direction: column; gap: 8px; }
  .pcf-label { font-family: var(--type_body_font, 'DM Sans', sans-serif); font-size: 14px; font-weight: 700; color: var(--brand-ink); }
  .pcf-label span { color: var(--brand-rust); } /* Red asterisk */

  /* Minimalist Form Inputs */
  .pcf-input, .pcf-textarea {
    appearance: none; background: #FFFFFF;
    border: 1px solid rgba(26, 23, 16, 0.2); border-radius: 2px;
    padding: 14px 16px; font-family: var(--type_body_font, 'DM Sans', sans-serif); font-size: 15px; color: var(--brand-ink);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .pcf-input::placeholder, .pcf-textarea::placeholder { color: rgba(26,23,16,0.4); }
  .pcf-textarea { resize: vertical; min-height: 120px; }
  
  .pcf-input:focus, .pcf-textarea:focus { outline: none; border-color: var(--brand-rust); box-shadow: 0 0 0 1px var(--brand-rust); }
  .pcf-input--error { border-color: #d32f2f; }

  /* Submit Button */
  .pcf-submit-btn {
    background-color: var(--brand-ink); color: #FFFFFF;
    border: none; border-radius: 2px; padding: 16px 32px;
    font-family: var(--type_body_font, 'DM Sans', sans-serif); font-size: 15px; font-weight: 700;
    cursor: pointer; transition: background-color 0.2s ease;
    align-self: flex-start; margin-top: 10px;
  }
  .pcf-submit-btn:hover { background-color: var(--brand-rust); }

  /* Messages */
  .pcf-success-msg { padding: 16px; background: #E8F5E9; border: 1px solid #4CAF50; color: #2E7D32; border-radius: 2px; font-size: 14px; margin-bottom: 20px;}
  .pcf-error-msg { padding: 16px; background: #FFEBEE; border: 1px solid #EF5350; color: #C62828; border-radius: 2px; font-size: 14px; margin-bottom: 20px;}

  /* Right Side: Image */
  .pcf-image-col { width: 100%; border-radius: 2px; overflow: hidden; }
  .pcf-side-img { width: 100%; height: 100%; object-fit: cover; }
  .pcf-placeholder-img { width: 100%; height: 100%; background: #f4f4f4; display: flex; align-items: center; justify-content: center; min-height: 400px; }
  .pcf-placeholder-svg { width: 100px; height: 100px; fill: rgba(26,23,16,0.1); }

  @media (max-width: 850px) {
    .pcf-grid { grid-template-columns: 1fr; gap: 40px; }
    .pcf-input-group { grid-template-columns: 1fr; }
    .pcf-image-col { order: -1; max-height: 300px; } /* Puts image above form on mobile */
  }
</style>

{% schema %}
{
  "name": "Premium Contact Form",
  "settings": [
    { "type": "text", "id": "form_heading", "label": "Heading", "default": "Send us a message" },
    { "type": "textarea", "id": "form_subheading", "label": "Subheading", "default": "Looking for advice on your next setup? Fill out the form below and a gear expert will get back to you." },
    { "type": "image_picker", "id": "side_image", "label": "Side Image", "info": "Upload a picture of your store, team, or a beautiful instrument." }
  ],
  "presets": [
    { "name": "Premium Contact Form" }
  ]
}
{% endschema %}