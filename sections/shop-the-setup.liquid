{%- comment -%}
  Stringer Music - Shop the Setup (Interactive Hotspots)
  A lifestyle image with interactive, pulsing product hotspots.
{%- endcomment -%}

<section 
  class="sts-section" 
  id="sts-{{ section.id }}"
  style="background-color: {{ section.settings.bg_color | default: '#F5F0E8' }};"
>
  <div class="sts-container">
    
    {%- comment -%} HEADER {%- endcomment -%}
    <div class="sts-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="sts-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="sts-heading">
          {%- assign parts = section.settings.heading | split: '|' -%}
          {%- for part in parts -%}
            {%- if forloop.index == 2 -%}<em>{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
          {%- endfor -%}
        </h2>
      {%- endif -%}
      
      {%- if section.settings.subtext != blank -%}
        <p class="sts-subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} INTERACTIVE IMAGE WRAPPER {%- endcomment -%}
    <div class="sts-image-area">
      
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 2000 | image_tag: 
          loading: 'lazy', 
          class: 'sts-main-image',
          alt: section.settings.heading 
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'sts-placeholder-image' }}
      {%- endif -%}

      {%- comment -%} HOTSPOTS LOOP {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        
        <div class="sts-hotspot" 
             style="top: {{ block.settings.pos_y }}%; left: {{ block.settings.pos_x }}%;" 
             {{ block.shopify_attributes }}>
          
          <button class="sts-dot" aria-label="View product details"></button>
          
          <div class="sts-tooltip">
            {%- if product != blank -%}
              <a href="{{ product.url }}" class="sts-product-card">
                <div class="sts-card-img">
                  {{ product.featured_image | image_url: width: 150 | image_tag: loading: 'lazy' }}
                </div>
                <div class="sts-card-info">
                  <span class="sts-card-title">{{ product.title }}</span>
                  <span class="sts-card-price">{{ product.price | money }}</span>
                  <span class="sts-card-link">View Details →</span>
                </div>
              </a>
            {%- else -%}
              {%- comment -%} Fallback if no product selected {%- endcomment -%}
              <a href="#" class="sts-product-card">
                <div class="sts-card-img">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
                <div class="sts-card-info">
                  <span class="sts-card-title">Select a Product</span>
                  <span class="sts-card-price">$199.00</span>
                  <span class="sts-card-link">View Details →</span>
                </div>
              </a>
            {%- endif -%}
          </div>
          
        </div>
      {%- endfor -%}

    </div>
  </div>
</section>

{% stylesheet %}
  /* ════════════════════════════════════════════
     BRAND VARIABLES & BASE
  ════════════════════════════════════════════ */
  .sts-section {
    --brand-ink: #1A1710;
    --brand-ink-rgb: 26, 23, 16;
    --brand-rust: #C8420A;
    --brand-cream: #F5F0E8;
    --font-heading: var(--type_header_font, 'Playfair Display', serif);
    --font-body: var(--type_body_font, 'DM Sans', sans-serif);
    
    padding: 80px 5%;
  }

  .sts-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ════════════════════════════════════════════
     HEADER STYLING
  ════════════════════════════════════════════ */
  .sts-header {
    text-align: center;
    margin-bottom: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .sts-eyebrow {
    font-family: var(--font-body); font-size: 11px; letter-spacing: 0.16em;
    text-transform: uppercase; color: rgba(var(--brand-ink-rgb), 0.55);
    margin: 0 0 16px; font-weight: 500; display: flex; align-items: center; gap: 16px;
  }
  .sts-eyebrow::before, .sts-eyebrow::after {
    content: ''; display: block; width: 32px; height: 1px; background-color: rgba(var(--brand-ink-rgb), 0.4);
  }

  .sts-heading {
    font-family: var(--font-heading); color: var(--brand-ink);
    font-size: clamp(36px, 4vw, 56px); font-weight: 900; margin: 0 0 16px;
    letter-spacing: -0.025em; line-height: 1.1;
  }
  .sts-heading em { font-style: italic; font-weight: 700; color: var(--brand-rust); }

  .sts-subtext {
    font-family: var(--font-body); font-size: 16px; color: rgba(var(--brand-ink-rgb), 0.7);
    margin: 0; max-width: 600px; line-height: 1.5;
  }

  /* ════════════════════════════════════════════
     IMAGE AREA
  ════════════════════════════════════════════ */
  .sts-image-area {
    position: relative;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    background-color: var(--brand-ink);
    box-shadow: 0 20px 40px rgba(var(--brand-ink-rgb), 0.08);
  }

  .sts-main-image, .sts-placeholder-image {
    display: block;
    width: 100%;
    height: auto;
    max-height: 800px;
    object-fit: cover;
  }

  .sts-placeholder-image {
    fill: rgba(255,255,255,0.2);
    background-color: rgba(var(--brand-ink-rgb), 0.05);
  }

  /* ════════════════════════════════════════════
     HOTSPOTS & PULSE ANIMATION
  ════════════════════════════════════════════ */
  .sts-hotspot {
    position: absolute;
    transform: translate(-50%, -50%); /* Centers the dot exactly on the coordinates */
    z-index: 2;
  }

  .sts-dot {
    position: relative;
    width: 24px; height: 24px;
    background-color: var(--brand-rust);
    border-radius: 50%; border: 3px solid #FFFFFF;
    cursor: pointer; padding: 0; outline: none;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    transition: transform 0.3s ease;
  }

  /* The radiating pulse ring */
  .sts-dot::before {
    content: ''; position: absolute;
    top: -3px; left: -3px; right: -3px; bottom: -3px;
    border-radius: 50%;
    border: 2px solid var(--brand-rust);
    animation: sts-pulse 2s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
  }

  @keyframes sts-pulse {
    0% { transform: scale(0.8); opacity: 1; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  .sts-dot:hover, .sts-hotspot.active .sts-dot {
    transform: scale(1.15);
  }

  /* ════════════════════════════════════════════
     TOOLTIP PRODUCT CARD
  ════════════════════════════════════════════ */
  .sts-tooltip {
    position: absolute;
    bottom: calc(100% + 16px);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    width: 260px;
    background-color: #FFFFFF;
    border-radius: 6px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.15);
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: 10;
  }

  /* Show tooltip on hover (desktop) or active class (mobile JS) */
  .sts-hotspot:hover .sts-tooltip,
  .sts-hotspot.active .sts-tooltip {
    opacity: 1; visibility: visible; pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  /* The little arrow pointing down to the dot */
  .sts-tooltip::after {
    content: ''; position: absolute;
    bottom: -6px; left: 50%; transform: translateX(-50%) rotate(45deg);
    width: 12px; height: 12px; background-color: #FFFFFF;
  }

  .sts-product-card {
    display: flex; align-items: center; gap: 12px;
    padding: 12px; text-decoration: none;
  }

  .sts-card-img {
    width: 64px; height: 64px; flex-shrink: 0;
    background-color: rgba(var(--brand-ink-rgb), 0.03);
    border-radius: 4px; overflow: hidden;
  }

  .sts-card-img img, .sts-card-img svg {
    width: 100%; height: 100%; object-fit: contain;
  }

  .sts-card-info {
    display: flex; flex-direction: column; justify-content: center;
  }

  .sts-card-title {
    font-family: var(--font-heading); font-size: 14px; font-weight: 700;
    color: var(--brand-ink); line-height: 1.2; margin-bottom: 4px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  .sts-card-price {
    font-family: var(--font-body); font-size: 13px; font-weight: 500;
    color: rgba(var(--brand-ink-rgb), 0.6); margin-bottom: 6px;
  }

  .sts-card-link {
    font-family: var(--font-body); font-size: 11px; font-weight: 700;
    text-transform: uppercase; color: var(--brand-rust); letter-spacing: 0.05em;
  }

  /* ════════════════════════════════════════════
     RESPONSIVE DESIGN
  ════════════════════════════════════════════ */
  @media screen and (max-width: 749px) {
    .sts-section { padding: 60px 5%; }
    /* Ensure tooltips don't run off the sides of mobile screens */
    .sts-tooltip { width: 220px; }
    /* Mobile constraint trick: If a dot is too far right, shift tooltip left */
    .sts-hotspot[style*="left: 8"], .sts-hotspot[style*="left: 9"] .sts-tooltip {
      left: auto; right: -20px; transform: translateX(0) translateY(10px);
    }
    .sts-hotspot[style*="left: 8"]:hover .sts-tooltip, .sts-hotspot[style*="left: 9"]:hover .sts-tooltip,
    .sts-hotspot.active[style*="left: 8"] .sts-tooltip, .sts-hotspot.active[style*="left: 9"] .sts-tooltip {
      transform: translateX(0) translateY(0);
    }
    .sts-hotspot[style*="left: 8"] .sts-tooltip::after, .sts-hotspot[style*="left: 9"] .sts-tooltip::after {
      left: auto; right: 26px; transform: none;
    }
  }
{% endstylesheet %}

<script>
  // Simple script to handle mobile tapping so tooltips stay open
  document.addEventListener('DOMContentLoaded', function() {
    const hotspots = document.querySelectorAll('.sts-hotspot');
    
    hotspots.forEach(hotspot => {
      hotspot.addEventListener('click', function(e) {
        // If it's already active, clicking the card will follow the link.
        // If not, it opens the tooltip and prevents following the link instantly.
        if (!this.classList.contains('active')) {
          e.preventDefault();
          // Close others
          hotspots.forEach(h => h.classList.remove('active'));
          // Open this one
          this.classList.add('active');
        }
      });
    });

    // Close when clicking outside
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.sts-hotspot')) {
        hotspots.forEach(h => h.classList.remove('active'));
      }
    });
  });
</script>

{% schema %}
{
  "name": "Shop the Setup",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F5F0E8"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "CURATED KITS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the |Setup|",
      "info": "Use | to make a word Rust and Italic."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Hover over the dots to explore the gear used to create this professional home studio."
    },
    {
      "type": "header",
      "content": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Photo",
      "info": "Upload a high-resolution, wide image (e.g., 2000px wide)."
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Product Hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "range",
          "id": "pos_x",
          "label": "Horizontal Position",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "default": 50,
          "info": "Moves the dot left to right."
        },
        {
          "type": "range",
          "id": "pos_y",
          "label": "Vertical Position",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "default": 50,
          "info": "Moves the dot top to bottom."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the Setup",
      "blocks": [
        {
          "type": "hotspot",
          "settings": { "pos_x": 30, "pos_y": 40 }
        },
        {
          "type": "hotspot",
          "settings": { "pos_x": 70, "pos_y": 60 }
        }
      ]
    }
  ]
}
{% endschema %}