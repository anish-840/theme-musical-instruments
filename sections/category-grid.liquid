{%- comment -%}
  Stringer Music - Category Grid Section
  Features: Responsive CSS Grid, Stringer Brand Colors/Typography, Interactive Hover States.
{%- endcomment -%}

<section 
  class="category-grid-section" 
  style="
    --grid-cols-desktop: {{ section.settings.desktop_columns }};
    --grid-cols-mobile: {{ section.settings.mobile_columns }};
    --bg-color: {{ section.settings.bg_color }};
  "
>
  <div class="cg-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="cg-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="cg-grid">
      {%- for block in section.blocks -%}
        {%- assign s = block.settings -%}
        <a href="{{ s.link | default: '#' }}" class="cg-card" {{ block.shopify_attributes }}>
          <div class="cg-card__image-wrapper cg-card__image-wrapper--{{ section.settings.image_style }}">
            {%- if s.image != blank -%}
              {{ s.image | image_url: width: 150 | image_tag: 
                class: 'cg-card__image', 
                loading: 'lazy', 
                alt: s.title 
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'cg-card__placeholder' }}
            {%- endif -%}
          </div>
          <span class="cg-card__title">{{ s.title | default: 'Category Name' }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* ════════════════════════════════════════════
     BRAND VARIABLES & BASE
  ════════════════════════════════════════════ */
  .category-grid-section {
    --brand-cream: #F5F0E8;
    --brand-ink: #1A1710;
    --brand-ink-rgb: 26, 23, 16;
    --brand-rust: #C8420A;
    
    --font-heading: var(--type_header_font, 'Playfair Display', serif);
    --font-body: var(--type_body_font, 'DM Sans', sans-serif);

    background-color: var(--bg-color, var(--brand-cream));
    padding: 60px 5%;
  }

  .cg-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ════════════════════════════════════════════
     TYPOGRAPHY
  ════════════════════════════════════════════ */
  .cg-heading {
    font-family: var(--font-heading);
    color: var(--brand-ink);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    text-align: center;
    margin: 0 0 48px;
    letter-spacing: -0.025em;
  }

  /* ════════════════════════════════════════════
     GRID LAYOUT
  ════════════════════════════════════════════ */
  .cg-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-cols-desktop, 3), 1fr);
    column-gap: 48px;
    row-gap: 0; /* Row gap is handled by the card padding/borders */
  }

  /* ════════════════════════════════════════════
     CATEGORY CARD (Interactive Row)
  ════════════════════════════════════════════ */
  .cg-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px 8px;
    text-decoration: none;
    border-bottom: 1px solid rgba(var(--brand-ink-rgb), 0.12); /* Stringer semi-transparent Ink */
    transition: border-color 0.3s ease;
    group: card;
  }

  /* Remove bottom border from the last few items depending on column count so it looks clean */
  .cg-card:nth-last-child(-n+3) {
    border-bottom: none;
  }

  .cg-card__image-wrapper {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Image Style Options */
  .cg-card__image-wrapper--circle {
    border-radius: 50%;
    background-color: #FFFFFF;
    border: 1px solid rgba(var(--brand-ink-rgb), 0.08);
  }
  .cg-card__image-wrapper--square {
    border-radius: 8px;
    background-color: #FFFFFF;
    border: 1px solid rgba(var(--brand-ink-rgb), 0.08);
  }

  .cg-card__image {
    width: 100%;
    height: 100%;
    object-fit: contain; /* Ensures product isn't cropped */
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .cg-card__placeholder {
    width: 100%;
    height: 100%;
    fill: rgba(var(--brand-ink-rgb), 0.2);
    background: rgba(var(--brand-ink-rgb), 0.05);
  }

  .cg-card__title {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: var(--brand-ink);
    line-height: 1.4;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  /* ════════════════════════════════════════════
     HOVER STATES
  ════════════════════════════════════════════ */
  .cg-card:hover {
    border-bottom-color: rgba(var(--brand-ink-rgb), 0.3);
  }

  .cg-card:hover .cg-card__title {
    color: var(--brand-rust); /* Shifts to brand accent color */
    transform: translateX(4px); /* Subtle nudge */
  }

  .cg-card:hover .cg-card__image {
    transform: scale(1.1); /* Slight pop on the image */
  }

  /* ════════════════════════════════════════════
     RESPONSIVE DESIGN
  ════════════════════════════════════════════ */
  @media screen and (max-width: 990px) {
    .category-grid-section { padding: 48px 5%; }
    .cg-grid { 
      grid-template-columns: repeat(2, 1fr); 
      column-gap: 32px;
    }
    /* Reset bottom borders for 2 columns */
    .cg-card { border-bottom: 1px solid rgba(var(--brand-ink-rgb), 0.12) !important; }
    .cg-card:nth-last-child(-n+2) { border-bottom: none !important; }
  }

  @media screen and (max-width: 749px) {
    .category-grid-section { padding: 40px 5%; }
    .cg-heading { font-size: 28px; margin-bottom: 32px; }
    .cg-grid { 
      grid-template-columns: repeat(var(--grid-cols-mobile, 1), 1fr); 
      column-gap: 16px;
    }
    .cg-card { padding: 16px 4px; }
    .cg-card__image-wrapper { width: 56px; height: 56px; }
    /* Reset bottom borders for mobile */
    .cg-card { border-bottom: 1px solid rgba(var(--brand-ink-rgb), 0.12) !important; }
    .cg-card:last-child { border-bottom: none !important; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Category Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Categories"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F5F0E8"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Columns on Desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns on Mobile",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "image_style",
      "label": "Image Wrapper Style",
      "options": [
        { "value": "transparent", "label": "Transparent (Native)" },
        { "value": "square", "label": "White Square with Border" },
        { "value": "circle", "label": "White Circle with Border" }
      ],
      "default": "transparent"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image",
          "info": "Transparent PNGs work best."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Name",
          "default": "Guitars and Basses"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Guitars and Basses" } },
        { "type": "category", "settings": { "title": "Drums and Percussion" } },
        { "type": "category", "settings": { "title": "Keys" } },
        { "type": "category", "settings": { "title": "Studio and Recording" } },
        { "type": "category", "settings": { "title": "Software" } },
        { "type": "category", "settings": { "title": "PA Equipment" } }
      ]
    }
  ]
}
{% endschema %}