{%- comment -%}
  Stringer Music - Category Cards Grid
  Features: Dynamic Product Counts, Eyebrow lines, Italic Accent Headings, Hover States, Bulletproof BG Color.
{%- endcomment -%}

<section 
  class="category-grid-section" 
  id="cg-{{ section.id }}"
  style="
    --grid-cols-desktop: {{ section.settings.desktop_columns }};
    --grid-cols-mobile: {{ section.settings.mobile_columns }};
    background-color: {{ section.settings.bg_color | default: '#FFFFFF' }};
  "
>
  <div class="cg-container">
    
    <div class="cg-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="cg-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="cg-heading">
          {%- assign parts = section.settings.heading | split: '|' -%}
          {%- for part in parts -%}
            {%- if forloop.index == 2 -%}<em>{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
          {%- endfor -%}
        </h2>
      {%- endif -%}
    </div>

    <div class="cg-grid">
      {%- for block in section.blocks -%}
        {%- assign s = block.settings -%}
        {%- assign collection = s.collection -%}

        {%- comment -%} Intelligent Fallbacks {%- endcomment -%}
        {%- assign card_link = collection.url | default: s.link | default: '#' -%}
        {%- assign card_title = s.title | default: collection.title | default: 'Category Name' -%}
        {%- assign card_image = s.image | default: collection.featured_image -%}
        
        {%- comment -%} Dynamic Subtitle Logic {%- endcomment -%}
        {%- if collection != blank -%}
          {%- assign card_subtitle = collection.all_products_count | append: ' items' -%}
        {%- else -%}
          {%- assign card_subtitle = s.subtitle -%}
        {%- endif -%}

        <a href="{{ card_link }}" class="cg-card" {{ block.shopify_attributes }}>
          
          <div class="cg-card__icon">
            {%- if card_image != blank -%}
              {{ card_image | image_url: width: 200 | image_tag: 
                loading: 'lazy', 
                alt: card_title 
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'cg-card__placeholder' }}
            {%- endif -%}
          </div>
          
          <div class="cg-card__content">
            <h3 class="cg-card__title">{{ card_title }}</h3>
            {%- if card_subtitle != blank -%}
              <p class="cg-card__subtitle">{{ card_subtitle }}</p>
            {%- endif -%}
          </div>

        </a>
      {%- endfor -%}
    </div>
    
  </div>
</section>

{% stylesheet %}
  /* ════════════════════════════════════════════
     BRAND VARIABLES & BASE
  ════════════════════════════════════════════ */
  .category-grid-section {
    --brand-cream: #F5F0E8;
    --brand-ink: #1A1710;
    --brand-ink-rgb: 26, 23, 16;
    --brand-rust: #C8420A;
    
    --font-heading: var(--type_header_font, 'Playfair Display', serif);
    --font-body: var(--type_body_font, 'DM Sans', sans-serif);

    /* Background color is handled directly by the inline HTML style above! */
    padding: 80px 5%;
  }

  .cg-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ════════════════════════════════════════════
     HEADER & TYPOGRAPHY
  ════════════════════════════════════════════ */
  .cg-header {
    margin-bottom: 48px;
    text-align: left;
  }

  .cg-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(var(--brand-ink-rgb), 0.55);
    margin: 0 0 16px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .cg-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background-color: rgba(var(--brand-ink-rgb), 0.4);
  }

  .cg-heading {
    font-family: var(--font-heading);
    color: var(--brand-ink);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 900;
    margin: 0;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .cg-heading em {
    font-style: italic;
    font-weight: 700;
    color: var(--brand-rust);
  }

  /* ════════════════════════════════════════════
     GRID LAYOUT
  ════════════════════════════════════════════ */
  .cg-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-cols-desktop, 5), 1fr);
    gap: 24px;
  }

  /* ════════════════════════════════════════════
     CATEGORY CARDS
  ════════════════════════════════════════════ */
  .cg-card {
    display: flex;
    flex-direction: column;
    padding: 32px 24px;
    background-color: transparent;
    border: 1px solid rgba(var(--brand-ink-rgb), 0.12);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    height: 100%;
  }

  .cg-card__icon {
    width: 80px; 
    height: 80px; 
    margin-bottom: 32px;
    display: flex;
    align-items: flex-end;
  }

  .cg-card__icon img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .cg-card__placeholder {
    fill: rgba(var(--brand-ink-rgb), 0.2);
    background: rgba(var(--brand-ink-rgb), 0.05);
    border-radius: 4px;
    width: 100%; height: 100%;
  }

  .cg-card__content {
    margin-top: auto;
  }

  .cg-card__title {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    color: var(--brand-ink);
    margin: 0 0 6px 0;
    line-height: 1.2;
    transition: color 0.3s ease;
  }

  .cg-card__subtitle {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(var(--brand-ink-rgb), 0.55);
    margin: 0;
    font-weight: 400;
  }

  /* ════════════════════════════════════════════
     HOVER STATES
  ════════════════════════════════════════════ */
  .cg-card:hover {
    border-color: var(--brand-rust);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(var(--brand-ink-rgb), 0.06);
  }

  /* ════════════════════════════════════════════
     RESPONSIVE DESIGN
  ════════════════════════════════════════════ */
  @media screen and (max-width: 1024px) {
    .cg-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media screen and (max-width: 749px) {
    .category-grid-section { padding: 60px 5%; }
    .cg-header { margin-bottom: 32px; }
    .cg-grid { 
      grid-template-columns: repeat(var(--grid-cols-mobile, 2), 1fr); 
      gap: 16px;
    }
    .cg-card { padding: 24px 16px; }
    .cg-card__icon { margin-bottom: 24px; width: 60px; height: 60px; } 
    .cg-card__title { font-size: 18px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Category Cards Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "BROWSE BY INSTRUMENT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What do you |play?|",
      "info": "Use | to wrap the word you want italicized and Rust colored."
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Columns on Desktop",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 5
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns on Mobile",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ],
      "default": "2"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection",
          "info": "This will automatically pull the product count (e.g., '1,240 items') and the collection link."
        },
        {
          "type": "header",
          "content": "Overrides"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Icon Override",
          "info": "Leave blank to use the collection's default image."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Name Override",
          "info": "Leave blank to use the collection's title. (e.g., Change 'Acoustic Guitars' to just 'Guitars')"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Fallback Subtitle",
          "default": "Explore collection",
          "info": "Only shows if NO collection is selected above."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Fallback Link",
          "info": "Only used if NO collection is selected above."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Cards Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Guitars" } },
        { "type": "category", "settings": { "title": "Keys & Synths" } },
        { "type": "category", "settings": { "title": "Drums" } },
        { "type": "category", "settings": { "title": "Wind & Brass" } },
        { "type": "category", "settings": { "title": "Strings" } }
      ]
    }
  ]
}
{% endschema %}