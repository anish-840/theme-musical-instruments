{%- comment -%}
  Stringer Music - Category Cards Grid
  Features: Card-based layout, Eyebrow lines, Italic Accent Headings, Hover States.
{%- endcomment -%}

<section 
  class="category-grid-section" 
  id="cg-{{ section.id }}"
  style="
    --grid-cols-desktop: {{ section.settings.desktop_columns }};
    --grid-cols-mobile: {{ section.settings.mobile_columns }};
    --bg-color: {{ section.settings.bg_color }};
  "
>
  <div class="cg-container">
    
    <div class="cg-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="cg-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="cg-heading">
          {%- assign parts = section.settings.heading | split: '|' -%}
          {%- for part in parts -%}
            {%- if forloop.index == 2 -%}<em>{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
          {%- endfor -%}
        </h2>
      {%- endif -%}
    </div>

    <div class="cg-grid">
      {%- for block in section.blocks -%}
        {%- assign s = block.settings -%}
        <a href="{{ s.link | default: '#' }}" class="cg-card" {{ block.shopify_attributes }}>
          
          <div class="cg-card__icon">
            {%- if s.image != blank -%}
              {{ s.image | image_url: width: 100 | image_tag: 
                loading: 'lazy', 
                alt: s.title 
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'cg-card__placeholder' }}
            {%- endif -%}
          </div>
          
          <div class="cg-card__content">
            <h3 class="cg-card__title">{{ s.title | default: 'Category Name' }}</h3>
            {%- if s.subtitle != blank -%}
              <p class="cg-card__subtitle">{{ s.subtitle }}</p>
            {%- endif -%}
          </div>

        </a>
      {%- endfor -%}
    </div>
    
  </div>
</section>

{% stylesheet %}
  /* ════════════════════════════════════════════
     BRAND VARIABLES & BASE
  ════════════════════════════════════════════ */
  .category-grid-section {
    --brand-cream: #F5F0E8;
    --brand-ink: #1A1710;
    --brand-ink-rgb: 26, 23, 16;
    --brand-rust: #C8420A;
    
    --font-heading: var(--type_header_font, 'Playfair Display', serif);
    --font-body: var(--type_body_font, 'DM Sans', sans-serif);

    background-color: var(--bg-color, var(--brand-cream));
    padding: 80px 5%;
  }

  .cg-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ════════════════════════════════════════════
     HEADER & TYPOGRAPHY
  ════════════════════════════════════════════ */
  .cg-header {
    margin-bottom: 48px;
    text-align: left;
  }

  .cg-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(var(--brand-ink-rgb), 0.55);
    margin: 0 0 16px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* The little line next to the eyebrow text */
  .cg-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background-color: rgba(var(--brand-ink-rgb), 0.4);
  }

  .cg-heading {
    font-family: var(--font-heading);
    color: var(--brand-ink);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 900;
    margin: 0;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  /* Accented Italic word inside the heading */
  .cg-heading em {
    font-style: italic;
    font-weight: 700;
    color: var(--brand-rust);
  }

  /* ════════════════════════════════════════════
     GRID LAYOUT
  ════════════════════════════════════════════ */
  .cg-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-cols-desktop, 5), 1fr);
    gap: 24px;
  }

  /* ════════════════════════════════════════════
     CATEGORY CARDS
  ════════════════════════════════════════════ */
  .cg-card {
    display: flex;
    flex-direction: column;
    padding: 32px 24px;
    background-color: transparent; /* Allows section BG to show through */
    border: 1px solid rgba(var(--brand-ink-rgb), 0.12); /* Stringer standard border */
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    height: 100%; /* Keeps cards even if text wraps */
  }

  .cg-card__icon {
    width: 44px;
    height: 44px;
    margin-bottom: 40px;
    display: flex;
    align-items: flex-end;
  }

  .cg-card__icon img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .cg-card__placeholder {
    fill: rgba(var(--brand-ink-rgb), 0.2);
    background: rgba(var(--brand-ink-rgb), 0.05);
    border-radius: 4px;
    width: 100%; height: 100%;
  }

  .cg-card__content {
    margin-top: auto; /* Pushes text to the bottom if cards are different heights */
  }

  .cg-card__title {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    color: var(--brand-ink);
    margin: 0 0 6px 0;
    line-height: 1.2;
    transition: color 0.3s ease;
  }

  .cg-card__subtitle {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(var(--brand-ink-rgb), 0.55);
    margin: 0;
    font-weight: 400;
  }

  /* ════════════════════════════════════════════
     HOVER STATES
  ════════════════════════════════════════════ */
  .cg-card:hover {
    border-color: var(--brand-rust);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(var(--brand-ink-rgb), 0.06);
    background-color: #FFFFFF; /* Gives it a solid pop against the Cream BG on hover */
  }

  /* ════════════════════════════════════════════
     RESPONSIVE DESIGN
  ════════════════════════════════════════════ */
  @media screen and (max-width: 1024px) {
    .cg-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media screen and (max-width: 749px) {
    .category-grid-section { padding: 60px 5%; }
    .cg-header { margin-bottom: 32px; }
    .cg-grid { 
      grid-template-columns: repeat(var(--grid-cols-mobile, 2), 1fr); 
      gap: 16px;
    }
    .cg-card { padding: 24px 16px; }
    .cg-card__icon { margin-bottom: 24px; width: 36px; height: 36px; }
    .cg-card__title { font-size: 18px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Category Cards Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F5F0E8"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "BROWSE BY INSTRUMENT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What do you |play?|",
      "info": "Use | to wrap the word you want italicized and Rust colored."
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Columns on Desktop",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 5
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns on Mobile",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ],
      "default": "2"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Icon",
          "info": "Small, transparent PNGs work best."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Name",
          "default": "Guitars"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "1,240 items",
          "info": "Leave blank to hide."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Cards Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Guitars", "subtitle": "1,240 items" } },
        { "type": "category", "settings": { "title": "Keys & Synths", "subtitle": "480 items" } },
        { "type": "category", "settings": { "title": "Drums", "subtitle": "360 items" } },
        { "type": "category", "settings": { "title": "Wind & Brass", "subtitle": "290 items" } },
        { "type": "category", "settings": { "title": "Strings", "subtitle": "210 items" } }
      ]
    }
  ]
}
{% endschema %}