{%- comment -%}
  Stringer Music - Gear Guides (Blog Grid)
  Editorial style blog grid that automatically pulls the latest articles.
{%- endcomment -%}

<section 
  class="gg-section" 
  id="gg-{{ section.id }}"
  style="background-color: {{ section.settings.bg_color | default: '#F5F0E8' }};"
>
  <div class="gg-container">
    
    <div class="gg-header-row">
      <div class="gg-header-text">
        {%- if section.settings.eyebrow != blank -%}
          <p class="gg-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="gg-heading">
            {%- assign parts = section.settings.heading | split: '|' -%}
            {%- for part in parts -%}
              {%- if forloop.index == 2 -%}<em>{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
            {%- endfor -%}
          </h2>
        {%- endif -%}
      </div>

      {%- assign blog = blogs[section.settings.blog] -%}
      {%- if section.settings.show_view_all and blog != blank -%}
        <a href="{{ blog.url }}" class="gg-view-all">Read All Guides <span aria-hidden="true">→</span></a>
      {%- endif -%}
    </div>

    <div class="gg-grid">
      {%- if blog != blank and blog.articles_count > 0 -%}
        
        {%- for article in blog.articles limit: section.settings.post_limit -%}
          <a href="{{ article.url }}" class="gg-card" aria-label="Read {{ article.title }}">
            
            <div class="gg-image-wrapper">
              {%- if article.image -%}
                {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'gg-image', alt: article.title }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'gg-placeholder' }}
              {%- endif -%}
            </div>
            
            <div class="gg-content">
              <span class="gg-date">{{ article.published_at | time_tag: format: 'date' }}</span>
              <h3 class="gg-title">{{ article.title }}</h3>
              <span class="gg-read-more">Read Article</span>
            </div>
            
          </a>
        {%- endfor -%}

      {%- else -%}
        
        {%- comment -%} ONBOARDING PLACEHOLDERS FIXED {%- endcomment -%}
        {%- for i in (1..section.settings.post_limit) -%}
          <div class="gg-card gg-card--placeholder">
            <div class="gg-image-wrapper">
              {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
              {{ 'collection-' | append: current | placeholder_svg_tag: 'gg-placeholder' }}
            </div>
            <div class="gg-content">
              <span class="gg-date">Today</span>
              <h3 class="gg-title">How to Choose Your First Instrument</h3>
              <span class="gg-read-more">Read Article</span>
            </div>
          </div>
        {%- endfor -%}

      {%- endif -%}
    </div>
    
  </div>
</section>

{% stylesheet %}
  /* ════════════════════════════════════════════
     BRAND VARIABLES & BASE
  ════════════════════════════════════════════ */
  .gg-section {
    --brand-ink: #1A1710;
    --brand-ink-rgb: 26, 23, 16;
    --brand-rust: #C8420A;
    --font-heading: var(--type_header_font, 'Playfair Display', serif);
    --font-body: var(--type_body_font, 'DM Sans', sans-serif);
    padding: 80px 5%;
    overflow: hidden;
  }

  .gg-container { max-width: 1400px; margin: 0 auto; }

  /* ════════════════════════════════════════════
     HEADER STYLING
  ════════════════════════════════════════════ */
  .gg-header-row {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 48px; gap: 24px;
  }

  .gg-eyebrow {
    font-family: var(--font-body); font-size: 11px; letter-spacing: 0.16em;
    text-transform: uppercase; color: rgba(var(--brand-ink-rgb), 0.55);
    margin: 0 0 16px; font-weight: 500; display: flex; align-items: center; gap: 16px;
  }
  .gg-eyebrow::before {
    content: ''; display: block; width: 32px; height: 1px; background-color: rgba(var(--brand-ink-rgb), 0.4);
  }

  .gg-heading {
    font-family: var(--font-heading); color: var(--brand-ink);
    font-size: clamp(36px, 4vw, 56px); font-weight: 900; margin: 0;
    letter-spacing: -0.025em; line-height: 1.1;
  }
  .gg-heading em { font-style: italic; font-weight: 700; color: var(--brand-rust); }

  .gg-view-all {
    font-family: var(--font-body); font-size: 15px; font-weight: 700;
    color: var(--brand-ink); text-decoration: none; border-bottom: 1px solid var(--brand-ink);
    padding-bottom: 4px; transition: all 0.3s ease; display: inline-flex; align-items: center; gap: 8px;
  }
  .gg-view-all:hover { color: var(--brand-rust); border-color: var(--brand-rust); }

  /* ════════════════════════════════════════════
     GRID & CARD STYLING
  ════════════════════════════════════════════ */
  .gg-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px;
  }

  .gg-card {
    text-decoration: none; display: flex; flex-direction: column; group: card;
  }

  .gg-image-wrapper {
    width: 100%; aspect-ratio: 16 / 10; overflow: hidden;
    border-radius: 4px; margin-bottom: 24px; background-color: rgba(var(--brand-ink-rgb), 0.05);
  }

  .gg-image {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gg-placeholder {
    width: 100%; height: 100%; fill: rgba(var(--brand-ink-rgb), 0.2);
    object-fit: cover;
  }

  .gg-content { display: flex; flex-direction: column; align-items: flex-start; }

  .gg-date {
    font-family: var(--font-body); font-size: 12px; font-weight: 500;
    text-transform: uppercase; letter-spacing: 0.05em; color: rgba(var(--brand-ink-rgb), 0.5);
    margin-bottom: 12px;
  }

  .gg-title {
    font-family: var(--font-heading); font-size: 24px; font-weight: 700;
    color: var(--brand-ink); margin: 0 0 16px 0; line-height: 1.3;
    transition: color 0.3s ease;
  }

  .gg-read-more {
    font-family: var(--font-body); font-size: 14px; font-weight: 700;
    color: var(--brand-rust); text-transform: uppercase; letter-spacing: 0.05em;
    display: inline-flex; align-items: center; position: relative;
  }

  .gg-read-more::after {
    content: ''; position: absolute; bottom: -2px; left: 0; width: 0%; height: 2px;
    background-color: var(--brand-rust); transition: width 0.3s ease;
  }

  /* ════════════════════════════════════════════
     HOVER STATES
  ════════════════════════════════════════════ */
  .gg-card:hover .gg-image { transform: scale(1.05); }
  .gg-card:hover .gg-title { color: var(--brand-rust); }
  .gg-card:hover .gg-read-more::after { width: 100%; }

  /* ════════════════════════════════════════════
     RESPONSIVE DESIGN
  ════════════════════════════════════════════ */
  @media screen and (max-width: 990px) {
    .gg-header-row { flex-direction: column; align-items: flex-start; gap: 16px; }
    .gg-grid { gap: 24px; }
    .gg-title { font-size: 20px; }
  }

  @media screen and (max-width: 749px) {
    .gg-section { padding: 60px 5%; }
    .gg-grid { 
      display: flex; overflow-x: auto; scroll-snap-type: x mandatory;
      gap: 16px; padding-bottom: 20px; scrollbar-width: none;
      margin: 0 -5%; padding-left: 5%; padding-right: 5%;
    }
    .gg-grid::-webkit-scrollbar { display: none; }
    .gg-card { flex: 0 0 calc(85% - 16px); scroll-snap-align: start; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gear Guides (Blog)",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F5F0E8"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "EDITORIAL & GUIDES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Read the |Manual|",
      "info": "Use | to make a word Rust and Italic."
    },
    {
      "type": "header",
      "content": "Blog Settings"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "Articles to show",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'Read All Guides' Link",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Gear Guides Grid"
    }
  ]
}
{% endschema %}