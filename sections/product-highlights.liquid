{%- comment -%}
  Stringer Music - Product Highlights Section
  Clean tabbed interface for Trends vs Top Sellers.
{%- endcomment -%}

<section class="ph-section" id="ph-{{ section.id }}" style="--bg-color: {{ section.settings.bg_color }}; --card-bg: {{ section.settings.card_bg }};">
  <div class="ph-container">
    
    <header class="ph-header">
      <h2 class="ph-main-heading">{{ section.settings.heading }}</h2>
      
      <div class="ph-tabs" role="tablist">
        <button class="ph-tab-btn active" data-tab="trends-{{ section.id }}" role="tab" aria-selected="true">
          {{ section.settings.tab_1_label }}
        </button>
        <button class="ph-tab-btn" data-tab="top-sellers-{{ section.id }}" role="tab" aria-selected="false">
          {{ section.settings.tab_2_label }}
        </button>
      </div>
    </header>

    {%- comment -%} TAB 1: TRENDS {%- endcomment -%}
    <div id="trends-{{ section.id }}" class="ph-tab-panel active" role="tabpanel">
      <div class="ph-grid">
        {%- if section.settings.collection_1 != blank -%}
          {%- for product in section.settings.collection_1.products limit: section.settings.products_to_show -%}
             {% render 'product-card-stringer', product: product %}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="ph-placeholder-card">Product Placeholder {{ i }}</div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} TAB 2: TOP SELLERS {%- endcomment -%}
    <div id="top-sellers-{{ section.id }}" class="ph-tab-panel" role="tabpanel">
      <div class="ph-grid">
        {%- if section.settings.collection_2 != blank -%}
          {%- for product in section.settings.collection_2.products limit: section.settings.products_to_show -%}
             {% render 'product-card-stringer', product: product %}
          {%- endfor -%}
        {%- else -%}
           {%- for i in (1..4) -%}
            <div class="ph-placeholder-card">Product Placeholder {{ i }}</div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<style>
  .ph-section {
    background-color: var(--bg-color);
    padding: 80px 0;
    --brand-ink: #1A1710;
    --brand-rust: #C8420A;
  }
  .ph-container { max-width: 1400px; margin: 0 auto; padding: 0 5%; }

  .ph-header { text-align: center; margin-bottom: 50px; }

  .ph-main-heading {
    font-family: var(--type_header_font, 'Playfair Display', serif);
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 900;
    color: var(--brand-ink);
    margin: 0 0 24px 0;
    letter-spacing: -0.02em;
  }

  /* Tabs Navigation */
  .ph-tabs {
    display: inline-flex;
    gap: 40px;
    position: relative;
  }

  .ph-tab-btn {
    background: none;
    border: none;
    font-family: var(--type_body_font, 'DM Sans', sans-serif);
    font-size: 18px;
    font-weight: 500;
    color: var(--brand-ink);
    cursor: pointer;
    padding: 8px 0;
    transition: color 0.3s ease;
    opacity: 0.6;
    position: relative;
  }

  .ph-tab-btn.active {
    opacity: 1;
    color: var(--brand-rust);
  }

  .ph-tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--brand-rust);
  }

  /* Grid Layout */
  .ph-tab-panel { display: none; }
  .ph-tab-panel.active { display: block; animation: phFadeIn 0.5s ease forwards; }

  .ph-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.cols_desktop }}, 1fr);
    gap: 30px;
  }

  @keyframes phFadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Placeholder logic */
  .ph-placeholder-card {
    background: #eee;
    height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Mobile Tweaks */
  @media screen and (max-width: 749px) {
    .ph-section { padding: 50px 0; }
    .ph-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 20px;
      gap: 15px;
    }
    .ph-grid > * {
      flex: 0 0 75%;
      scroll-snap-align: start;
    }
    .ph-tabs { gap: 20px; }
    .ph-tab-btn { font-size: 16px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('#ph-{{ section.id }}');
    const tabs = section.querySelectorAll('.ph-tab-btn');
    const panels = section.querySelectorAll('.ph-tab-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');

        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        panels.forEach(p => p.classList.remove('active'));

        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        section.querySelector(`#${target}`).classList.add('active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product Highlights",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Product Highlights"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F5F0E8"
    },
    {
      "type": "header",
      "content": "Tab 1: Trends"
    },
    {
      "type": "text",
      "id": "tab_1_label",
      "label": "Tab 1 Label",
      "default": "Trends"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Collection for Tab 1"
    },
    {
      "type": "header",
      "content": "Tab 2: Top Sellers"
    },
    {
      "type": "text",
      "id": "tab_2_label",
      "label": "Tab 2 Label",
      "default": "Top Sellers"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Collection for Tab 2"
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "label": "Columns on Desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Product Highlights Stringer"
    }
  ]
}
{% endschema %}