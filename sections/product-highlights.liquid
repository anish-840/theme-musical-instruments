{%- comment -%}
  Stringer Music - Product Highlights Carousel
  Upgraded: Custom Web Component JS for stability, improved arrow positioning, and smoother scrolling.
{%- endcomment -%}

<product-highlights class="ph-section" style="--bg-color: {{ section.settings.bg_color }};">
  <div class="ph-container">
    
    <header class="ph-header">
      <h2 class="ph-main-heading">{{ section.settings.heading }}</h2>
      
      <div class="ph-controls-row">
        <div class="ph-tabs" role="tablist">
          <button class="ph-tab-btn active" data-target="trends-{{ section.id }}" role="tab" aria-selected="true">
            {{ section.settings.tab_1_label }}
          </button>
          <button class="ph-tab-btn" data-target="top-sellers-{{ section.id }}" role="tab" aria-selected="false">
            {{ section.settings.tab_2_label }}
          </button>
        </div>
      </div>
    </header>

    {%- comment -%} CAROUSEL WRAPPER {%- endcomment -%}
    <div class="ph-carousel-wrapper">
      
      {%- if section.settings.show_nav -%}
        <button class="ph-arrow prev" aria-label="Slide Left">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="ph-arrow next" aria-label="Slide Right">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      {%- endif -%}

      {%- comment -%} TAB 1: TRENDS {%- endcomment -%}
      <div id="trends-{{ section.id }}" class="ph-tab-panel active" role="tabpanel">
        <div class="ph-grid-carousel">
          {%- if section.settings.collection_1 != blank -%}
            {%- for product in section.settings.collection_1.products limit: section.settings.products_to_show -%}
               <div class="ph-carousel-item">
                 {% render 'product-card-stringer', product: product %}
               </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              <div class="ph-carousel-item">
                <div style="background:#fff; padding:20px; text-align:center; border:1px solid #eee; height:300px; display:flex; align-items:center; justify-content:center;">
                  Select a collection
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} TAB 2: TOP SELLERS {%- endcomment -%}
      <div id="top-sellers-{{ section.id }}" class="ph-tab-panel" role="tabpanel">
        <div class="ph-grid-carousel">
          {%- if section.settings.collection_2 != blank -%}
            {%- for product in section.settings.collection_2.products limit: section.settings.products_to_show -%}
               <div class="ph-carousel-item">
                 {% render 'product-card-stringer', product: product %}
               </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              <div class="ph-carousel-item">
                <div style="background:#fff; padding:20px; text-align:center; border:1px solid #eee; height:300px; display:flex; align-items:center; justify-content:center;">
                  Select a collection
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

    </div>

  </div>
</product-highlights>

<style>
  /* Base & Container */
  .ph-section { display: block; background-color: var(--bg-color); padding: 80px 0; --brand-ink: #1A1710; --brand-rust: #C8420A; }
  .ph-container { max-width: 1400px; margin: 0 auto; padding: 0 5%; position: relative; }
  
  /* Header & Typography */
  .ph-header { text-align: center; margin-bottom: 40px; }
  .ph-main-heading { font-family: var(--type_header_font, 'Playfair Display', serif); font-size: clamp(32px, 4vw, 44px); font-weight: 900; color: var(--brand-ink); margin: 0 0 24px 0; letter-spacing: -0.01em; }

  /* Tabs */
  .ph-controls-row { display: flex; justify-content: center; align-items: center; }
  .ph-tabs { display: inline-flex; gap: 40px; position: relative; }
  
  .ph-tab-btn {
    background: none; border: none; font-family: var(--type_body_font, 'DM Sans', sans-serif);
    font-size: 18px; font-weight: 600; color: var(--brand-ink);
    cursor: pointer; padding: 8px 4px; transition: all 0.3s ease; opacity: 0.5; position: relative;
  }
  .ph-tab-btn:hover { opacity: 0.8; }
  .ph-tab-btn.active { opacity: 1; color: var(--brand-rust); }
  .ph-tab-btn.active::after {
    content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 2px; background-color: var(--brand-rust);
    animation: slideIn 0.3s ease forwards;
  }
  @keyframes slideIn { from { transform: scaleX(0); } to { transform: scaleX(1); } }

  /* Carousel Wrapper & Arrows */
  .ph-carousel-wrapper { position: relative; margin: 0 -20px; padding: 0 20px; }
  
  .ph-arrow {
    position: absolute;
    top: calc(50% - 20px);
    transform: translateY(-50%);
    background: #FFFFFF; 
    color: var(--brand-ink);
    border: 1px solid rgba(26,23,16,0.08); 
    width: 48px; height: 48px;
    border-radius: 50%; 
    cursor: pointer; 
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    opacity: 0; 
    pointer-events: none; 
    z-index: 10;
    box-shadow: 0 8px 20px rgba(26,23,16,0.08);
  }
  .ph-carousel-wrapper:hover .ph-arrow { opacity: 1; pointer-events: auto; }
  
  /* Pulled outside the grid slightly */
  .ph-arrow.prev { left: -10px; }
  .ph-arrow.next { right: -10px; }
  
  .ph-arrow:hover { background: var(--brand-rust); color: #FFFFFF; border-color: var(--brand-rust); transform: translateY(-50%) scale(1.05); }

  /* Panels & Grid */
  .ph-tab-panel { display: none; animation: fadeIn 0.4s ease; }
  .ph-tab-panel.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  
  .ph-grid-carousel {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 24px;
    padding: 10px 0 30px 0; /* Padding allows drop-shadows on cards to breathe */
    -ms-overflow-style: none; scrollbar-width: none;
  }
  .ph-grid-carousel::-webkit-scrollbar { display: none; }

  .ph-carousel-item {
    flex: 0 0 calc(25% - 18px); /* 4 items per row exactly */
    scroll-snap-align: start;
  }

  /* Responsive Constraints */
  @media screen and (max-width: 1200px) {
    .ph-carousel-item { flex: 0 0 calc(33.33% - 16px); }
  }
  @media screen and (max-width: 850px) {
    .ph-carousel-item { flex: 0 0 calc(50% - 12px); }
  }
  @media screen and (max-width: 749px) {
    .ph-section { padding: 50px 0; }
    .ph-header { margin-bottom: 30px; }
    .ph-carousel-item { flex: 0 0 80%; }
    .ph-arrow { display: none; } /* Hide arrows on mobile, prioritize native swiping */
    .ph-tabs { gap: 20px; }
  }
</style>

<script>
  if (!customElements.get('product-highlights')) {
    class ProductHighlights extends HTMLElement {
      constructor() {
        super();
        this.tabs = this.querySelectorAll('.ph-tab-btn');
        this.panels = this.querySelectorAll('.ph-tab-panel');
        this.prevBtn = this.querySelector('.ph-arrow.prev');
        this.nextBtn = this.querySelector('.ph-arrow.next');

        // Bind Tab Clicks
        this.tabs.forEach(tab => {
          tab.addEventListener('click', (e) => this.switchTab(e.currentTarget));
        });

        // Bind Arrow Clicks
        if (this.prevBtn && this.nextBtn) {
          this.prevBtn.addEventListener('click', () => this.scrollGrid(-1));
          this.nextBtn.addEventListener('click', () => this.scrollGrid(1));
        }
      }

      switchTab(clickedTab) {
        const targetId = clickedTab.getAttribute('data-target');
        
        // Reset states
        this.tabs.forEach(t => t.classList.remove('active'));
        this.panels.forEach(p => p.classList.remove('active'));
        
        // Activate selected
        clickedTab.classList.add('active');
        const targetPanel = this.querySelector(`#${targetId}`);
        if (targetPanel) {
          targetPanel.classList.add('active');
          // Reset scroll position on tab change
          const grid = targetPanel.querySelector('.ph-grid-carousel');
          if(grid) grid.scrollLeft = 0;
        }
      }

      scrollGrid(direction) {
        const activePanel = this.querySelector('.ph-tab-panel.active');
        if (!activePanel) return;
        
        const grid = activePanel.querySelector('.ph-grid-carousel');
        if (!grid) return;

        // Scrolls by 75% of the visible container width for a smooth "page" feel
        const scrollAmount = grid.clientWidth * 0.75; 
        grid.scrollBy({ left: scrollAmount * direction, behavior: 'smooth' });
      }
    }
    
    customElements.define('product-highlights', ProductHighlights);
  }
</script>

{% schema %}
{
  "name": "Product Highlights Tabs",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Product Highlights" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5F0E8" },
    { "type": "checkbox", "id": "show_nav", "label": "Show Hover Arrows (Desktop)", "default": true },
    { "type": "header", "content": "Collections" },
    { "type": "text", "id": "tab_1_label", "label": "Tab 1 Name", "default": "Trends" },
    { "type": "collection", "id": "collection_1", "label": "Collection 1" },
    { "type": "text", "id": "tab_2_label", "label": "Tab 2 Name", "default": "Top Sellers" },
    { "type": "collection", "id": "collection_2", "label": "Collection 2" },
    { "type": "range", "id": "products_to_show", "label": "Max Products per tab", "min": 4, "max": 20, "default": 8 }
  ],
  "presets": [{ "name": "Product Highlights Tabs" }]
}
{% endschema %}