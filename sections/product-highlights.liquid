{%- comment -%}
  Stringer Music - Product Highlights Carousel
  Clean tabbed interface with smooth horizontal scrolling.
{%- endcomment -%}

<section class="ph-section" id="ph-{{ section.id }}" style="--bg-color: {{ section.settings.bg_color }};">
  <div class="ph-container">
    
    <header class="ph-header">
      <h2 class="ph-main-heading">{{ section.settings.heading }}</h2>
      
      <div class="ph-controls-row">
        <div class="ph-tabs" role="tablist">
          <button class="ph-tab-btn active" data-tab="trends-{{ section.id }}" role="tab" aria-selected="true">
            {{ section.settings.tab_1_label }}
          </button>
          <button class="ph-tab-btn" data-tab="top-sellers-{{ section.id }}" role="tab" aria-selected="false">
            {{ section.settings.tab_2_label }}
          </button>
        </div>

        {%- if section.settings.show_nav -%}
          <div class="ph-nav-arrows">
            <button class="ph-arrow prev" aria-label="Slide Left">❮</button>
            <button class="ph-arrow next" aria-label="Slide Right">❯</button>
          </div>
        {%- endif -%}
      </div>
    </header>

    {%- comment -%} TAB 1: TRENDS {%- endcomment -%}
    <div id="trends-{{ section.id }}" class="ph-tab-panel active" role="tabpanel">
      <div class="ph-grid-carousel">
        {%- if section.settings.collection_1 != blank -%}
          {%- for product in section.settings.collection_1.products limit: section.settings.products_to_show -%}
             {% render 'product-card-stringer', product: product %}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} TAB 2: TOP SELLERS {%- endcomment -%}
    <div id="top-sellers-{{ section.id }}" class="ph-tab-panel" role="tabpanel">
      <div class="ph-grid-carousel">
        {%- if section.settings.collection_2 != blank -%}
          {%- for product in section.settings.collection_2.products limit: section.settings.products_to_show -%}
             {% render 'product-card-stringer', product: product %}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<style>
  .ph-section { background-color: var(--bg-color); padding: 80px 0; --brand-ink: #1A1710; --brand-rust: #C8420A; overflow: hidden; }
  .ph-container { max-width: 1400px; margin: 0 auto; padding: 0 5%; position: relative; }
  .ph-header { text-align: center; margin-bottom: 40px; }
  .ph-main-heading {
    font-family: var(--type_header_font, 'Playfair Display', serif);
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 900;
    color: var(--brand-ink);
    margin: 0 0 30px 0;
  }

  .ph-controls-row {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    margin-bottom: 20px;
  }

  .ph-tabs { display: inline-flex; gap: 40px; }
  .ph-tab-btn {
    background: none; border: none; font-family: var(--type_body_font, 'DM Sans', sans-serif);
    font-size: 18px; font-weight: 500; color: var(--brand-ink);
    cursor: pointer; padding: 8px 0; transition: all 0.3s ease; opacity: 0.4; position: relative;
  }
  .ph-tab-btn.active { opacity: 1; color: var(--brand-rust); }
  .ph-tab-btn.active::after {
    content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 2px; background-color: var(--brand-rust);
  }

  .ph-nav-arrows { position: absolute; right: 0; display: flex; gap: 10px; }
  .ph-arrow {
    background: #fff; border: 1px solid rgba(26,23,16,0.12); width: 40px; height: 40px;
    border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }
  .ph-arrow:hover { background: var(--brand-ink); color: #fff; }

  /* CAROUSEL GRID */
  .ph-tab-panel { display: none; }
  .ph-tab-panel.active { display: block; }
  
  .ph-grid-carousel {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 30px;
    padding-bottom: 10px;
    -ms-overflow-style: none; scrollbar-width: none;
  }
  .ph-grid-carousel::-webkit-scrollbar { display: none; }

  .ph-grid-carousel > * {
    flex: 0 0 calc(25% - 22.5px); /* 4 items per row */
    scroll-snap-align: start;
  }

  @media screen and (max-width: 1100px) {
    .ph-grid-carousel > * { flex: 0 0 calc(33.33% - 20px); }
  }
  @media screen and (max-width: 749px) {
    .ph-grid-carousel > * { flex: 0 0 80%; }
    .ph-nav-arrows { display: none; } /* Use touch swipe on mobile */
    .ph-tabs { gap: 20px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('#ph-{{ section.id }}');
    
    // Tab Logic
    section.querySelectorAll('.ph-tab-btn').forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');
        section.querySelectorAll('.ph-tab-btn').forEach(t => t.classList.remove('active'));
        section.querySelectorAll('.ph-tab-panel').forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        section.querySelector(`#${target}`).classList.add('active');
      });
    });

    // Arrow Logic
    const nextBtn = section.querySelector('.ph-arrow.next');
    const prevBtn = section.querySelector('.ph-arrow.prev');

    if(nextBtn && prevBtn) {
      nextBtn.addEventListener('click', () => {
        const activeGrid = section.querySelector('.ph-tab-panel.active .ph-grid-carousel');
        activeGrid.scrollBy({ left: activeGrid.offsetWidth, behavior: 'smooth' });
      });
      prevBtn.addEventListener('click', () => {
        const activeGrid = section.querySelector('.ph-tab-panel.active .ph-grid-carousel');
        activeGrid.scrollBy({ left: -activeGrid.offsetWidth, behavior: 'smooth' });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Product Highlights",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Product Highlights" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5F0E8" },
    { "type": "checkbox", "id": "show_nav", "label": "Show Desktop Arrows", "default": true },
    { "type": "header", "content": "Collections" },
    { "type": "text", "id": "tab_1_label", "label": "Tab 1 Name", "default": "Trends" },
    { "type": "collection", "id": "collection_1", "label": "Collection 1" },
    { "type": "text", "id": "tab_2_label", "label": "Tab 2 Name", "default": "Top Sellers" },
    { "type": "collection", "id": "collection_2", "label": "Collection 2" },
    { "type": "range", "id": "products_to_show", "label": "Max Products", "min": 4, "max": 20, "default": 8 }
  ],
  "presets": [{ "name": "Product Highlights" }]
}
{% endschema %}