{%- comment -%}
  Stringer Music - Featured Video Split
  A premium 50/50 split screen with video/image on one side and typography on the other.
{%- endcomment -%}

<section 
  class="fv-section" 
  id="fv-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
  "
>
  <div class="fv-container">
    <div class="fv-layout {% if section.settings.media_position == 'right' %}fv-layout--reverse{% endif %}">
      
      {%- comment -%} MEDIA COLUMN {%- endcomment -%}
      <div class="fv-media-col">
        <div class="fv-media-wrapper">
          
          {%- if section.settings.hosted_video != blank -%}
            {{ section.settings.hosted_video | video_tag: 
              autoplay: section.settings.autoplay, 
              loop: section.settings.loop, 
              muted: section.settings.autoplay, 
              controls: section.settings.controls,
              class: 'fv-video-element' 
            }}
          {%- elsif section.settings.video_url != blank -%}
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=0&rel=0" class="fv-iframe" frameborder="0" allowfullscreen></iframe>
            {%- elsif section.settings.video_url.type == 'vimeo' -%}
              <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}" class="fv-iframe" frameborder="0" allowfullscreen></iframe>
            {%- endif -%}
          {%- elsif section.settings.cover_image != blank -%}
            {{ section.settings.cover_image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'fv-image-fallback' }}
          {%- else -%}
            {{ 'collection-2' | placeholder_svg_tag: 'fv-placeholder' }}
          {%- endif -%}

        </div>
      </div>

      {%- comment -%} TEXT COLUMN {%- endcomment -%}
      <div class="fv-text-col">
        <div class="fv-text-content">
          
          {%- if section.settings.eyebrow != blank -%}
            <p class="fv-eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="fv-heading">
              {%- assign parts = section.settings.heading | split: '|' -%}
              {%- for part in parts -%}
                {%- if forloop.index == 2 -%}<em>{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
              {%- endfor -%}
            </h2>
          {%- endif -%}

          {%- if section.settings.text != blank -%}
            <div class="fv-description">
              {{ section.settings.text }}
            </div>
          {%- endif -%}

          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link | default: '#' }}" class="fv-button">
              {{ section.settings.button_label }}
            </a>
          {%- endif -%}

        </div>
      </div>

    </div>
  </div>
</section>

{% stylesheet %}
  /* ════════════════════════════════════════════
     BRAND VARIABLES & BASE
  ════════════════════════════════════════════ */
  .fv-section {
    --brand-ink: #1A1710;
    --brand-ink-rgb: 26, 23, 16;
    --brand-rust: #C8420A;
    --font-heading: var(--type_header_font, 'Playfair Display', serif);
    --font-body: var(--type_body_font, 'DM Sans', sans-serif);
    
    padding: 80px 5%;
    overflow: hidden;
  }

  .fv-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ════════════════════════════════════════════
     LAYOUT GRID
  ════════════════════════════════════════════ */
  .fv-layout {
    display: flex;
    align-items: center;
    gap: 80px;
  }

  .fv-layout--reverse {
    flex-direction: row-reverse;
  }

  .fv-media-col, .fv-text-col {
    flex: 1;
    width: 50%;
  }

  /* ════════════════════════════════════════════
     MEDIA STYLING
  ════════════════════════════════════════════ */
  .fv-media-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    overflow: hidden;
    background-color: rgba(var(--brand-ink-rgb), 0.05);
    box-shadow: 0 20px 40px rgba(var(--brand-ink-rgb), 0.08);
  }

  .fv-video-element, .fv-image-fallback {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .fv-iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .fv-placeholder {
    width: 100%; height: 100%;
    fill: rgba(var(--brand-ink-rgb), 0.2);
  }

  /* ════════════════════════════════════════════
     TEXT STYLING
  ════════════════════════════════════════════ */
  .fv-text-content {
    max-width: 540px;
  }

  .fv-layout--reverse .fv-text-content {
    margin-left: auto; /* Aligns text properly when reversed */
  }

  .fv-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(var(--brand-ink-rgb), 0.55);
    margin: 0 0 24px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .fv-eyebrow::before {
    content: ''; display: block; width: 32px; height: 1px;
    background-color: rgba(var(--brand-ink-rgb), 0.4);
  }

  .fv-heading {
    font-family: var(--font-heading);
    color: var(--brand-ink);
    font-size: clamp(36px, 4vw, 56px);
    font-weight: 900;
    margin: 0 0 24px;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .fv-heading em {
    font-style: italic; font-weight: 700; color: var(--brand-rust);
  }

  .fv-description {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: rgba(var(--brand-ink-rgb), 0.75);
    margin: 0 0 40px;
  }

  /* ════════════════════════════════════════════
     BUTTON STYLING
  ════════════════════════════════════════════ */
  .fv-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 36px;
    background-color: var(--brand-ink);
    color: #FFFFFF;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .fv-button:hover {
    background-color: var(--brand-rust);
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(200, 66, 10, 0.2); /* Rust colored glow */
  }

  /* ════════════════════════════════════════════
     RESPONSIVE DESIGN
  ════════════════════════════════════════════ */
  @media screen and (max-width: 990px) {
    .fv-layout { gap: 48px; }
  }

  @media screen and (max-width: 749px) {
    .fv-section { padding: 60px 5%; }
    .fv-layout, .fv-layout--reverse { flex-direction: column; gap: 40px; }
    .fv-media-col, .fv-text-col { width: 100%; }
    .fv-text-content { max-width: 100%; margin-left: 0; }
    .fv-media-wrapper { aspect-ratio: 16 / 9; } /* Widescreen ratio for mobile */
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Video Split",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Media Position (Desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "video",
      "id": "hosted_video",
      "label": "Shopify Hosted Video",
      "info": "Upload an MP4 directly to Shopify."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "label": "YouTube/Vimeo Link",
      "info": "Used if no Shopify Hosted Video is selected."
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Fallback Image",
      "info": "Shows if no video is added."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay & Mute (Hosted Video Only)",
      "default": true,
      "info": "Great for 'living background' aesthetic."
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop Video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show Video Controls",
      "default": false
    },
    {
      "type": "header",
      "content": "Text Settings"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "HEAR THE DIFFERENCE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Sound of |Perfection|",
      "info": "Use | to make a word Rust and Italic."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Experience the rich resonance and immaculate build quality of our flagship series. Watch our master builders take you through the details.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop The Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Featured Video Split"
    }
  ]
}
{% endschema %}