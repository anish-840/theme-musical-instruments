{%- comment -%}
  Stringer Music - Custom Newsletter Banner
  Matches the full-width red editorial design from the screenshot.
{%- endcomment -%}

<section class="cnb-section color-{{ section.settings.color_scheme }}" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="cnb-container">
    
    <div class="cnb-text-wrapper">
      {%- if section.settings.heading != blank -%}
        <h2 class="cnb-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.subheading != blank -%}
        <p class="cnb-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="cnb-form-wrapper">
      {%- form 'customer', class: 'cnb-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        
        <div class="cnb-input-group">
          <label for="NewsletterInput-{{ section.id }}" class="visually-hidden">Email</label>
          <input
            id="NewsletterInput-{{ section.id }}"
            type="email"
            name="contact[email]"
            class="cnb-input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            placeholder="{{ section.settings.placeholder_text }}"
            required
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="Newsletter-error--{{ section.id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="Newsletter-success--{{ section.id }}"
            {% endif %}
          >
          <button type="submit" class="cnb-button" name="commit" id="Subscribe-{{ section.id }}" style="background-color: {{ section.settings.button_bg_color }}; color: {{ section.settings.button_text_color }};">
            {{ section.settings.button_label }}
          </button>
        </div>

        {%- if form.errors -%}
          <div class="cnb-message cnb-message--error" id="Newsletter-error--{{ section.id }}">
            <svg viewBox="0 0 20 20" aria-hidden="true" class="cnb-icon"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" fill="currentColor"/></svg>
            {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <div class="cnb-message cnb-message--success" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>
            <svg viewBox="0 0 20 20" aria-hidden="true" class="cnb-icon"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" fill="currentColor"/></svg>
            Thanks for subscribing!
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>

  </div>
</section>

<style>
  .cnb-section {
    padding: 80px 5%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .cnb-container {
    width: 100%;
    max-width: 800px;
    text-align: center;
  }

  .cnb-heading {
    font-family: var(--type_header_font, 'Playfair Display', serif);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    margin: 0 0 15px 0;
    letter-spacing: -0.02em;
    color: inherit;
  }

  .cnb-subheading {
    font-family: var(--type_body_font, 'DM Sans', sans-serif);
    font-size: 16px;
    line-height: 1.5;
    margin: 0 0 30px 0;
    color: inherit;
    opacity: 0.9;
  }

  .cnb-form-wrapper {
    max-width: 500px;
    margin: 0 auto;
  }

  .cnb-input-group {
    display: flex;
    gap: 10px;
    align-items: stretch;
  }

  .cnb-input {
    flex: 1;
    background-color: transparent;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 4px;
    padding: 12px 20px;
    color: inherit;
    font-family: var(--type_body_font, 'DM Sans', sans-serif);
    font-size: 15px;
    transition: border-color 0.2s ease;
  }

  .cnb-input::placeholder {
    color: inherit;
    opacity: 0.7;
  }

  .cnb-input:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 1);
  }

  .cnb-button {
    border: none;
    border-radius: 4px;
    padding: 12px 30px;
    font-family: var(--type_body_font, 'DM Sans', sans-serif);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.1s ease;
    white-space: nowrap;
  }

  .cnb-button:hover {
    opacity: 0.85;
  }
  
  .cnb-button:active {
    transform: scale(0.98);
  }

  .cnb-message {
    margin-top: 15px;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .cnb-icon {
    width: 18px;
    height: 18px;
  }

  .visually-hidden {
    position: absolute !important;
    overflow: hidden;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    clip: rect(0 0 0 0);
    word-wrap: normal !important;
  }

  /* Mobile Layout */
  @media screen and (max-width: 600px) {
    .cnb-section {
      padding: 60px 5%;
    }
    .cnb-input-group {
      flex-direction: column;
    }
    .cnb-button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Newsletter Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#D1310C"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Border Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#1A1710"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay in tune with us"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "New arrivals, exclusive deals, and event announcements — straight to your inbox. No spam, ever."
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Input Placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Custom Newsletter Banner"
    }
  ]
}
{% endschema %}